{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": ["js/**/*.js", "carousel/src/**/*.jsx"],
  "exclude": ["node_modules", "**/node_modules", "dist", "api", "worker.js", "server.js"]
}
